# CurricMesh self-host configuration. Copy to `.env` and fill in:
#     cp .env.example .env
# docker compose reads .env automatically. NEVER commit your real .env.

# ---------------------------------------------------------------------------
# Public domain. The single HTTPS URL you give to customers.
#   - Real deploy: a domain whose DNS A record points at this server's IP.
#     Caddy auto-provisions a Let's Encrypt cert on first request.
#   - Local smoke test: set DOMAIN=localhost (Caddy then serves plain HTTP at
#     http://localhost; no certificate is issued for localhost).
DOMAIN=curricmesh.example.com

# Email for Let's Encrypt/ACME registration + expiry notices. Required for a
# real domain; ignored for localhost.
ACME_EMAIL=you@example.com

# ---------------------------------------------------------------------------
# Postgres OWNER (superuser) password. Used by the db container and by the
# migrate/alembic/seed steps. Pick a strong value.
#   e.g.  openssl rand -hex 24
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Password for the least-privilege runtime app role `curricmesh_app` (the role
# the live API connects as, so Postgres row-level security engages). Distinct
# from POSTGRES_PASSWORD. Pick a strong value.
#   e.g.  openssl rand -hex 24
APP_DB_PASSWORD=change-me-strong-app-role-password

# ---------------------------------------------------------------------------
# Application secret for signing JWTs. MUST be >= 32 bytes or the API refuses
# to boot in production. Generate one:
#   openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Anthropic API key — OPTIONAL. Enables the AI "impact analysis" feature.
# Leave blank to run without it (the UI shows a graceful 503 notice). Set later
# and `docker compose up -d` to enable.
ANTHROPIC_API_KEY=
