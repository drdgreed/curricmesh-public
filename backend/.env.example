# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# PostgreSQL connection string (asyncpg driver for the app).
# docker-compose maps Postgres to host port 5432 — matches the docker-compose.yml default.
DATABASE_URL=postgresql+asyncpg://curricmesh:curricmesh@localhost:5432/curricmesh

# Optional sync URL used by Alembic (psycopg2 driver). If omitted, Alembic falls back to DATABASE_URL.
DATABASE_URL_SYNC=postgresql+psycopg2://curricmesh:curricmesh@localhost:5432/curricmesh

# Secret key for signing JWT tokens — generate with: openssl rand -hex 32
# In production, must be at least 32 bytes or the app will refuse to start.
SECRET_KEY=replace-me-with-a-real-secret

# Anthropic API key (leave empty until Milestone C AI features are needed)
ANTHROPIC_API_KEY=

# AI model: claude-opus-4-8 (default, balanced) | claude-fable-5 (most capable, ~2x cost, may refuse → falls back to Opus 4.8)
AI_MODEL=claude-opus-4-8

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Application environment — set to "production" on deployed servers.
APP_ENV=development

# ---------------------------------------------------------------------------
# Notifications (B6) — leave empty to disable the channel
# ---------------------------------------------------------------------------

# Slack incoming webhook URL. Get from: https://api.slack.com/messaging/webhooks
# Leave empty to disable Slack notifications.
SLACK_WEBHOOK_URL=

# SMTP settings for email notifications.
# Leave SMTP_HOST or NOTIFY_EMAIL_TO empty to disable email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
